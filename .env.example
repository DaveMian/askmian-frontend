# Ask Mian Frontend — Environment Variables

# Your Railway backend API URL
# Replace with your actual Railway URL after deploying backend
VITE_API_URL=https://your-backend.up.railway.app/api/trpc

# Your Stripe publishable key (from https://dashboard.stripe.com/apikeys)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_publishable_key

# App ID (same as backend APP_ID)
VITE_APP_ID=your_app_id
